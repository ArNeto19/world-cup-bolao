rules_version = '3';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ───────────────────────────────────────────────────────────────
    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }

    function role() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isAdmin()  { return isAuth() && role() == 'admin'; }
    function isPlayer() { return isAuth() && (role() == 'player' || role() == 'admin'); }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read their own doc (needed for role check on login)
      allow read: if isAuth() && uid() == userId;
      // Admins can read all users (for the admin panel)
      allow read: if isAdmin();
      // New user creates their own doc on first login
      allow create: if isAuth() && uid() == userId;
      // User can update their own displayName; admin can update role
      allow update: if (isAuth() && uid() == userId) || isAdmin();
    }

    // ── groups ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read, create, update: if isPlayer();
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read:   if isPlayer();
        allow create: if isPlayer() && uid() == memberId;
        allow delete: if (isPlayer() && uid() == memberId) || isAdmin();
        allow update: if isAdmin();
      }
    }

    // ── matches ───────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read:  if isPlayer();
      allow write: if isAdmin();
    }

    // ── predictions ───────────────────────────────────────────────────────────
    match /predictions/{predId} {
      allow read:          if isPlayer();
      allow create, update: (if isPlayer() && request.resource.data.userId == uid()) || isAdmin();
      allow delete:        if isAdmin();
    }
  }
}
